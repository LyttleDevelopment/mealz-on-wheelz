# ─── Cloudflare Turnstile ─────────────────────────────────────────────────────
# Get keys at: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Set to "true" to bypass Turnstile verification in local development only
TURNSTILE_BYPASS_IN_DEV=true

# ─── Resend (email delivery) ──────────────────────────────────────────────────
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender address (must match a verified domain in Resend)
BOOKING_FROM_EMAIL=bookings@yourdomain.com

# Internal inbox that receives all new booking-request notifications
BOOKING_NOTIFICATION_TO=team@yourdomain.com

# Optional: CC address for internal notifications
BOOKING_NOTIFICATION_CC=

# Reply-to address on customer acknowledgment emails (defaults to from address)
BOOKING_REPLY_TO=contact@yourdomain.com

# ─── Google Calendar ──────────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/library
# https://console.cloud.google.com/iam-admin/serviceaccounts
# Setup:
# 1. Create a Google Cloud project
# 2. Enable the Google Calendar API
# 3. Create a service account and download the JSON key
# 4. Share your dedicated booking-requests calendar with the service account email
# 5. Give it "Make changes to events" permission
#
# To share your calendar with the service account:
# 1. Open Google Calendar
# 2. Find your booking-requests calendar in the sidebar → click the three dots → Settings and sharing
# 3. Scroll to Share with specific people or groups
# 4. Add mow-367@mealz-on-weelz.iam.gserviceaccount.com
# 5. Set permission to "Make changes to events"
# 6. Save

GOOGLE_SERVICE_ACCOUNT_EMAIL=booking-bot@your-project.iam.gserviceaccount.com

# Copy the private_key field from the downloaded service account JSON
# Keep the full value including -----BEGIN PRIVATE KEY----- markers
# Escape newlines as \n when storing in this file
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# The calendar ID of your dedicated booking-requests calendar
# Found under: Google Calendar > Settings > [calendar name] > Calendar ID
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

